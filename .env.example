# Get your free API keys at:
#   Gemini      https://aistudio.google.com/apikey
#   Groq        https://console.groq.com/keys
#   OpenRouter  https://openrouter.ai/keys
#
# You don't need all three — the router skips providers with missing keys.

GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Port the server listens on.
PORT=3000

# Required on every /ai request via the `x-secret-token` header (or ?token=).
# Pick any long random string. Leave blank to disable auth (local dev only).
SECRET_TOKEN=
